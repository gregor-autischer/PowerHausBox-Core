HA_SSH_HOST=192.168.1.201
HA_SSH_PORT=22
HA_SSH_USER=root

# If you use 1Password SSH agent, this can be the generated *.pub file.
HA_SSH_KEY_FILE=/Users/you/.ssh/1Password/YOUR_KEY_FINGERPRINT.pub
HA_SSH_AUTH_SOCK=/Users/you/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock

HA_REMOTE_REPO_PATH=/addons/local/powerhausbox
HA_ADDON_SLUG=local_powerhausbox_cloudflare_tunnel

PHB_STUDIO_BASE_URL=https://studio.powerhaus.ai
PHB_AUTO_ENABLE_IFRAME_EMBEDDING=true
PHB_UI_AUTH_ENABLED=false

# Optional: if empty and PHB_UI_AUTH_ENABLED=true, deploy script generates a random one per run.
# PHB_UI_PASSWORD=change-me
